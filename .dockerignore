logs/
debug/
data/
image/
*.log
*.trace
*.tmp
*.bak
test.txt

# 历史归档代码只用于本地临时迁移
archived_plugins/
archived_plugins_config/

# 无需进入镜像上下文的本地说明和脚本
docs/
run.bat
docker-compose.yml

