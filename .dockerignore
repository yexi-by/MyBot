env/

# 真实配置、密钥与个人隐私
setting.toml
setting.local.toml
*.secret.toml
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# 插件真实配置包含群号、提示词和私有开关，禁止进入镜像上下文
plugins_config/

